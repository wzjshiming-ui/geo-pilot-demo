.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top, rgba(88, 187, 255, 0.22), transparent 32%),
    radial-gradient(circle at bottom right, rgba(255, 163, 92, 0.16), transparent 28%),
    linear-gradient(180deg, #09131f, #02060d);
}

.game-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hud {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 5;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.brand-card,
.stats-card,
.tips-card,
.overlay-card {
  background: rgba(9, 18, 30, 0.82);
  border: 1px solid rgba(166, 209, 255, 0.18);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.32);
  backdrop-filter: blur(16rpx);
}

.brand-card {
  padding: 26rpx;
  border-radius: 30rpx;
}

.eyebrow {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(116, 247, 213, 0.12);
  color: #74f7d5;
  font-size: 22rpx;
  letter-spacing: 0.18em;
}

.title {
  margin-top: 16rpx;
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.desc {
  margin-top: 12rpx;
  color: #9ab1ca;
  font-size: 28rpx;
  line-height: 1.5;
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 30rpx;
}

.stat-item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-label {
  color: #9ab1ca;
  font-size: 22rpx;
  letter-spacing: 0.08em;
}

.stat-value {
  color: #eef5ff;
  font-size: 52rpx;
  font-weight: 800;
}

.tips-card {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  color: #9ab1ca;
  font-size: 24rpx;
}

.avatar-actions {
  position: absolute;
  right: 24rpx;
  bottom: 38rpx;
  z-index: 6;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.avatar-btn {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(166, 209, 255, 0.22);
  background: rgba(9, 18, 30, 0.82);
  color: #eef5ff;
  font-size: 26rpx;
}

.avatar-btn::after {
  border: 0;
}

.joystick-zone {
  position: absolute;
  left: 24rpx;
  bottom: 24rpx;
  width: 280rpx;
  height: 280rpx;
  z-index: 6;
}

.joystick-base {
  position: absolute;
  left: 40rpx;
  top: 40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.04);
  box-shadow: inset 0 0 40rpx rgba(255, 255, 255, 0.05);
  transition: opacity 120ms ease;
}

.joystick-base--active {
  background: rgba(116, 247, 213, 0.08);
  border-color: rgba(116, 247, 213, 0.22);
}

.joystick-stick {
  position: absolute;
  left: 60rpx;
  top: 60rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(116, 247, 213, 0.92), rgba(255, 197, 107, 0.92));
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.2);
}

.overlay {
  position: absolute;
  inset: 0;
  z-index: 7;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(2, 5, 10, 0.68);
}

.overlay-card {
  width: 100%;
  max-width: 680rpx;
  padding: 34rpx;
  border-radius: 36rpx;
  text-align: center;
}

.overlay-tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 111, 97, 0.12);
  color: #ffb0a7;
  font-size: 24rpx;
}

.overlay-title {
  margin-top: 20rpx;
  color: #eef5ff;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1.2;
}

.overlay-text {
  margin-top: 16rpx;
  color: #9ab1ca;
  font-size: 30rpx;
  line-height: 1.6;
}

.overlay-records {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.overlay-record {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.04);
  text-align: left;
}

.overlay-record__label {
  display: block;
  color: #9ab1ca;
  font-size: 22rpx;
}

.overlay-record__value {
  display: block;
  margin-top: 8rpx;
  color: #eef5ff;
  font-size: 42rpx;
  font-weight: 800;
}

.restart-btn {
  margin-top: 28rpx;
  border: 0;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #74f7d5, #ffc56b);
  color: #09131f;
  font-size: 30rpx;
  font-weight: 800;
}

.restart-btn::after {
  border: 0;
}
